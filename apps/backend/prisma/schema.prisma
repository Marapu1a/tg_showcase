generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  ACTIVE
  HIDDEN
  ARCHIVED
}

enum OfferStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OfferEventType {
  BUY_CLICK
  DETAIL_CLICK
}

model User {
  id             String  @id @default(cuid())
  telegramUserId String  @unique
  username       String?
  firstName      String?
  lastName       String?

  products Product[]
  offers   Offer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Product {
  id            String        @id @default(cuid())
  ownerUserId   String
  title         String
  description   String?
  priceText     String
  checkoutUrl   String
  status        ProductStatus @default(ACTIVE)
  quantityLimit Int?

  ownerUser   User           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  images      ProductImage[]
  offers      Offer[]
  offerEvents OfferEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId])
  @@index([status])
  @@index([createdAt])
}

model ProductImage {
  id        String @id @default(cuid())
  productId String
  fileUrl   String
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([sortOrder])
}

model Offer {
  id          String @id @default(cuid())
  productId   String
  ownerUserId String

  title  String
  text   String?
  status OfferStatus @default(DRAFT)

  channelId         String?
  telegramMessageId String?
  publishedAt       DateTime?

  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  ownerUser User         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  events    OfferEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([ownerUserId])
  @@index([status])
  @@index([publishedAt])
}

model OfferEvent {
  id                   String         @id @default(cuid())
  offerId              String
  productId            String
  type                 OfferEventType
  viewerTelegramUserId String?

  offer   Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([offerId])
  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@index([viewerTelegramUserId])
}
